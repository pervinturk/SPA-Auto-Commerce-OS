# SPA Center — Environment Variable Template
# Copy this file to `.env` and fill in your real credentials.
# .env is gitignored, never commit your real keys.

# ---------------- Gemini AI (Google AI Studio) ----------------
# Get free-tier keys from: https://aistudio.google.com/app/apikey
# Comma-separated list — pool rotates on rate-limit (429) errors.
GEMINI_API_KEYS=
GEMINI_MODEL_PRIMARY=gemini-2.5-flash
GEMINI_MODEL_SECONDARY=gemini-2.5-pro

# ---------------- Trendyol Marketplace API ----------------
# Trendyol Partner > Entegrasyon Bilgilerim
TRENDYOL_SELLER_ID=
TRENDYOL_API_KEY=
TRENDYOL_API_SECRET=
TRENDYOL_BRAND_ID=
TRENDYOL_BRAND_NAME=

# ---------------- Optional Local SLM (llama.cpp) ----------------
# Path to a GGUF model file for on-device inference.
# Leave empty to use Gemini cloud only.
LOCAL_SLM_PATH=
LOCAL_SLM_CTX=4096
LOCAL_SLM_THREADS=4
LOCAL_SLM_GPU_LAYERS=0

# ---------------- Application Mode ----------------
# LIVE: pulls real data from Trendyol API (default)
# MOCK: uses bundled demo data (for development / screenshots)
EAAS_DATA_MODE=LIVE

# ---------------- Currency / FX ----------------
# Optional override for fallback USD/TRY rate when external API unavailable
FX_FALLBACK_RATE=
